# Banco de dados
# IMPORTANTE: o driver +asyncpg é obrigatório — o engine async do SQLAlchemy
# falha silenciosamente se for omitido (cai num driver síncrono e quebra em runtime).
DATABASE_URL=postgresql+asyncpg://nesis:nesis@localhost:5432/nesis

# Aplicação
APP_ENV=development
APP_VERSION=0.2.0

# Postgres (usado pelo docker-compose)
POSTGRES_USER=nesis
POSTGRES_PASSWORD=nesis
POSTGRES_DB=nesis

# Gemini
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash

# PGVector (driver psycopg, síncrono — a busca async é feita via asyncio.to_thread).
# Dentro do Docker, host = "postgres". Fora do Docker, host = "localhost".
PGVECTOR_URL=postgresql+psycopg://nesis:nesis@localhost:5432/nesis

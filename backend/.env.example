# Banco de dados (use SQLite para fallback simples, PostgreSQL para RAG)
# Para SQLite (fallback):
DATABASE_URL=sqlite+aiosqlite:///./nesis.db
# Para PostgreSQL com pgvector (RAG completo):
# DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/nesis

# Redis (cache)
REDIS_URL=redis://localhost:6379

# App
APP_ENV=development
APP_VERSION=0.2.0

# Google Gemini (RAG) - OBRIGATORIO para RAG
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="chave_de_api_aqui"
GEMINI_MODEL=gemini-2.0-flash

# MLflow (opcional)
MLFLOW_TRACKING_URI=file://mlruns

# PostgreSQL (usado pelo docker-compose)
POSTGRES_USER=nesis
POSTGRES_PASSWORD=nesis
POSTGRES_DB=nesis

# PGVector (para busca vetorial)
PGVECTOR_URL=postgresql+asyncpg://nesis:nesis@localhost:5432/nesis
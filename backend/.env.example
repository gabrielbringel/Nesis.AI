# Banco de dados
# IMPORTANTE: o driver +asyncpg é obrigatório — o engine async do SQLAlchemy
# falha silenciosamente se for omitido (cai num driver síncrono e quebra em runtime).
DATABASE_URL=postgresql+asyncpg://nesis:nesis@localhost:5432/nesis

# Aplicação
APP_ENV=development
APP_VERSION=0.2.0

# Postgres (usado pelo docker-compose)
POSTGRES_USER=nesis
POSTGRES_PASSWORD=nesis
POSTGRES_DB=nesis
